---
/**
 * Team Section (home)
 * Showcases the medical team with portraits and a CTA to /equipo
 */

import { Image } from 'astro:assets';
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import Button from '../ui/Button.astro';
import { type Lang, getTranslations, getRoute } from '../../i18n';
import rafaPortrait from '../../assets/rafa-portrait.jpg';
import nataliaPortrait from '../../assets/natalia-portrait.jpg';
import luciaPortrait from '../../assets/lucia-portrait.jpg';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const portraits = {
  'rafael-fraile': rafaPortrait,
  'natalia-golubtsova': nataliaPortrait,
  'lucia-mascia': luciaPortrait,
};
---

<section id="equipo" class="py-section lg:py-section-lg bg-white">
  <Container>
    <!-- Header -->
    <div class="text-center mb-12 lg:mb-16 max-w-3xl mx-auto">
      <SectionHeading
        eyebrow={t.home.team.eyebrow}
        title={t.home.team.title}
        description={t.home.team.description}
        level={2}
        align="center"
      />
    </div>

    <!-- Team Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
      {t.home.team.members.map((member) => {
        const portrait = portraits[member.slug as keyof typeof portraits];
        return (
          <article class="group">
            <div class="relative mb-6 overflow-hidden rounded-2xl aspect-[4/5] bg-primary-50">
              {portrait && (
                <Image
                  src={portrait}
                  alt={member.name}
                  format="webp"
                  quality={80}
                  widths={[300, 500, 700]}
                  sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                  loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-slow group-hover:scale-105"
                />
              )}
              <!-- Subtle teal overlay on hover -->
              <div class="absolute inset-0 bg-gradient-to-t from-primary/30 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-normal"></div>
            </div>

            <h3 class="text-subheading font-semibold text-text mb-1">
              {member.name}
            </h3>
            <p class="text-body-sm text-primary font-medium mb-3">
              {member.role}
            </p>
            <p class="text-body-sm text-text-secondary leading-relaxed">
              {member.bio}
            </p>
          </article>
        );
      })}
    </div>

    <!-- CTAs -->
    <div class="mt-14 flex flex-col sm:flex-row gap-4 justify-center">
      <Button href={getRoute('team', lang)} variant="primary" size="lg">
        {t.home.team.cta}
      </Button>
      <Button href={getRoute('patientCare', lang)} variant="outline" size="lg">
        {t.home.hero.cta}
      </Button>
    </div>
  </Container>
</section>
