---
/**
 * Testimonials Block Section
 * Heading, subtitle about verified reviews, and placeholder testimonial cards
 * with star ratings. Ready for future Google/Doctoralia widget integration.
 */

import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import Card from '../ui/Card.astro';
import { type Lang, getTranslations } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
---

<section id="opiniones" class="py-section lg:py-section-lg bg-white">
  <Container>
    <!-- Header -->
    <div class="text-center mb-12 lg:mb-16">
      <SectionHeading
        eyebrow={t.home.testimonials.eyebrow}
        title={t.home.testimonials.title}
        description={t.home.testimonials.subtitle}
        level={2}
        align="center"
      />
    </div>

    <!-- Testimonial Cards Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {t.home.testimonials.placeholders.map((testimonial: { name: string; text: string; rating: number }) => (
        <Card variant="bordered" padding="lg" class="flex flex-col">
          <!-- Star rating -->
          <div class="flex gap-1 mb-4" aria-label={`${testimonial.rating} out of 5 stars`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <svg
                class={`w-5 h-5 ${i < testimonial.rating ? 'text-amber-400' : 'text-gray-200'}`}
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="text-body-sm text-text-secondary leading-relaxed mb-5 flex-grow">
            &ldquo;{testimonial.text}&rdquo;
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-4 border-t border-border">
            <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center flex-shrink-0">
              <span class="text-body-sm font-semibold text-primary">
                {testimonial.name.charAt(0)}
              </span>
            </div>
            <p class="text-body-sm font-medium text-text">
              {testimonial.name}
            </p>
          </div>
        </Card>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-10 text-center">
      <a
        href="#"
        class="inline-flex items-center gap-2 text-body font-medium text-primary hover:text-primary-dark transition-colors"
      >
        {t.home.testimonials.cta}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>

    <!-- Widget placeholder area -->
    <!-- Future: Replace the cards above with a Google/Doctoralia reviews widget -->
  </Container>
</section>
