---
/**
 * Easy Process Section
 * Shows 3 numbered steps of how to get an appointment, with icons.
 * Simple vertical or horizontal layout.
 */

import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { type Lang, getTranslations } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const stepIcons = [
  // Message / write icon
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />`,
  // Phone icon
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />`,
  // Calendar / check icon
  `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />`,
];
---

<section id="pedir-cita" class="py-section lg:py-section-lg bg-primary-50/30">
  <Container>
    <!-- Header -->
    <div class="text-center mb-12 lg:mb-16">
      <SectionHeading
        eyebrow={t.home.easyProcess.eyebrow}
        title={t.home.easyProcess.title}
        level={2}
        align="center"
      />
    </div>

    <!-- Steps -->
    <div class="grid sm:grid-cols-3 gap-8 lg:gap-12 max-w-4xl mx-auto">
      {t.home.easyProcess.steps.map((step: { number: string; title: string; description: string }, index: number) => (
        <div class="relative flex flex-col items-center text-center">
          <!-- Icon with number badge -->
          <div class="relative mb-6">
            <div class="w-16 h-16 bg-white rounded-2xl shadow-sm flex items-center justify-center">
              <svg class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={stepIcons[index]} />
            </div>
            <span class="absolute -top-2 -right-2 w-7 h-7 bg-primary text-white text-xs font-bold rounded-full flex items-center justify-center shadow-sm">
              {step.number}
            </span>
          </div>

          <!-- Content -->
          <h3 class="text-subheading font-semibold text-text mb-2">
            {step.title}
          </h3>
          <p class="text-body-sm text-text-secondary leading-relaxed max-w-xs">
            {step.description}
          </p>
        </div>
      ))}
    </div>

    <!-- Note -->
    <div class="mt-10 text-center">
      <p class="text-body-sm text-text-muted italic max-w-2xl mx-auto">
        {t.home.easyProcess.note}
      </p>
    </div>
  </Container>
</section>
