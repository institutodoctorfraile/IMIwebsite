---
/**
 * Treatments Grid Section
 * Cards showcasing available treatments with links to detail sections
 */

import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import Card from '../ui/Card.astro';
import { type Lang, getTranslations, getRoute } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);

// Treatment cards data
const treatments = [
  {
    key: 'laserCo2',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />`,
    routeKey: 'treatmentLaserCo2',
  },
  {
    key: 'rf',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />`,
    routeKey: 'treatmentRf',
  },
  {
    key: 'emsella',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />`,
    routeKey: 'treatmentEmsella',
  },
  {
    key: 'prp',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />`,
    routeKey: 'treatmentPrp',
  },
  {
    key: 'bioidenticalHt',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />`,
    routeKey: 'treatmentBioidenticalHt',
  },
  {
    key: 'magnetotherapy',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />`,
    routeKey: 'treatmentMagnetotherapy',
  },
];
---

<section id="tratamientos" class="py-section lg:py-section-lg bg-white">
  <Container>
    <!-- Header -->
    <div class="text-center mb-12 lg:mb-16">
      <SectionHeading
        eyebrow={t.home.treatmentsSection.eyebrow}
        title={t.home.treatmentsSection.title}
        description={t.home.treatmentsSection.description}
        level={2}
        align="center"
      />
    </div>

    <!-- Treatment Cards Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {treatments.map((treatment) => {
        const cardData = t.home.treatmentsSection.cards[treatment.key as keyof typeof t.home.treatmentsSection.cards];
        const href = getRoute(treatment.routeKey, lang);
        
        return (
          <Card variant="bordered" padding="lg" class="group hover:border-primary/30 transition-all duration-normal">
            <!-- Icon -->
            <div class="w-14 h-14 mb-5 bg-primary/10 rounded-xl flex items-center justify-center group-hover:bg-primary/20 transition-colors">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={treatment.icon} />
            </div>
            
            <!-- Content -->
            <h3 class="text-subheading font-semibold text-text mb-3 group-hover:text-primary transition-colors">
              {cardData.title}
            </h3>
            
            <p class="text-body-sm text-text-secondary mb-5 line-clamp-3">
              {cardData.description}
            </p>
            
            <!-- Link -->
            <a 
              href={href}
              class="inline-flex items-center gap-2 text-body-sm font-medium text-primary hover:text-primary-dark transition-colors"
            >
              {t.home.treatmentsSection.viewMore}
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </Card>
        );
      })}
    </div>
  </Container>
</section>
