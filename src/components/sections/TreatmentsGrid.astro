---
/**
 * Treatments Grid Section
 * Cards showcasing available treatments with links to detail pages
 */

import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { type Lang, getTranslations, getRoute } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const treatments = [
  { key: 'laserCo2', routeKey: 'treatmentLaserCo2' },
  { key: 'rf', routeKey: 'treatmentRf' },
  { key: 'emsella', routeKey: 'treatmentEmsella' },
  { key: 'prp', routeKey: 'treatmentPrp' },
  { key: 'bioidenticalHt', routeKey: 'treatmentBioidenticalHt' },
  { key: 'magnetotherapy', routeKey: 'treatmentMagnetotherapy' },
];
---

<section id="tratamientos" class="py-section lg:py-section-lg bg-white">
  <Container>
    <!-- Header -->
    <div class="text-center mb-8 md:mb-12 lg:mb-16">
      <SectionHeading
        eyebrow={t.home.treatmentsSection.eyebrow}
        title={t.home.treatmentsSection.title}
        description={t.home.treatmentsSection.description}
        level={2}
        align="center"
      />
    </div>

    <!-- Treatment Cards Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6 lg:gap-8">
      {treatments.map((treatment) => {
        const cardData = t.home.treatmentsSection.cards[treatment.key as keyof typeof t.home.treatmentsSection.cards];
        const href = getRoute(treatment.routeKey, lang);

        return (
          <a
            href={href}
            class="group relative flex flex-col rounded-card bg-primary-50 border-l-4 border-primary p-6 md:p-8 transition-all duration-normal hover:bg-primary hover:-translate-y-1 hover:shadow-card-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
          >
            <h3 class="text-subheading font-semibold text-primary-700 mb-2 md:mb-3 transition-colors group-hover:text-white">
              {cardData.title}
            </h3>

            <p class="text-body-sm text-text-secondary mb-4 md:mb-6 line-clamp-3 flex-1 transition-colors group-hover:text-white/90">
              {cardData.description}
            </p>

            <span class="inline-flex items-center gap-2 text-body-sm font-medium text-primary transition-colors group-hover:text-white">
              {t.home.treatmentsSection.viewMore}
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        );
      })}
    </div>
  </Container>
</section>
