---
/**
 * Services Block Section
 * Three service cards in a responsive grid with icon placeholders, titles,
 * descriptions, tags, and CTA links.
 */

import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import Card from '../ui/Card.astro';
import { type Lang, getTranslations, getRoute } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const services = [
  {
    key: 'obstetrics' as const,
    route: 'obstetrics',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />`,
  },
  {
    key: 'intimateHealth' as const,
    route: 'regenerative',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />`,
  },
  {
    key: 'gynecology' as const,
    route: 'gynecology',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`,
  },
];
---

<section id="servicios" class="py-section lg:py-section-lg bg-white">
  <Container>
    <!-- Header -->
    <div class="text-center mb-12 lg:mb-16">
      <SectionHeading
        eyebrow={t.home.services.eyebrow}
        title={t.home.services.title}
        level={2}
        align="center"
      />
    </div>

    <!-- Service Cards Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {services.map((service) => {
        const cardData = t.home.services.cards[service.key];
        const href = getRoute(service.route, lang);

        return (
          <Card variant="bordered" padding="lg" class="group hover:border-primary/30 transition-all duration-normal">
            <!-- Icon -->
            <div class="w-14 h-14 mb-5 bg-primary/10 rounded-xl flex items-center justify-center group-hover:bg-primary/20 transition-colors">
              <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={service.icon} />
            </div>

            <!-- Content -->
            <h3 class="text-subheading font-semibold text-text mb-3 group-hover:text-primary transition-colors">
              {cardData.title}
            </h3>

            <p class="text-body-sm text-text-secondary mb-4 line-clamp-3">
              {cardData.description}
            </p>

            <!-- Tags -->
            {cardData.tags && cardData.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-5">
                {cardData.tags.map((tag: string) => (
                  <span class="inline-block text-xs font-medium bg-primary-50 text-primary px-2.5 py-1 rounded-full">
                    {tag}
                  </span>
                ))}
              </div>
            )}

            <!-- Link -->
            <a
              href={href}
              class="inline-flex items-center gap-2 text-body-sm font-medium text-primary hover:text-primary-dark transition-colors"
            >
              {t.home.services.viewMore}
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </Card>
        );
      })}
    </div>

    <!-- Note -->
    <div class="mt-10 text-center">
      <p class="text-body-sm text-text-muted italic max-w-2xl mx-auto">
        {t.home.services.note}
      </p>
    </div>
  </Container>
</section>
