---
/**
 * Hero Section
 * Main hero banner for the homepage
 */

import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import { type Lang, getTranslations, getRoute } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
---

<section id="hero" class="relative z-0 bg-gradient-to-br from-primary-50 via-white to-white overflow-hidden">
  <!-- Decorative elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 -left-20 w-60 h-60 bg-primary/5 rounded-full blur-3xl"></div>
  </div>

  <Container class="relative">
    <div class="py-16 md:py-24 lg:py-32">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Content -->
        <div class="text-center lg:text-left">
          <p class="text-primary font-medium text-body-sm uppercase tracking-wider mb-4 animate-fade-in">
            {t.home.hero.eyebrow}
          </p>
          
          <h1 class="text-display-sm md:text-display lg:text-display-lg text-text font-bold mb-6 text-balance animate-fade-in-up">
            {t.home.hero.title}
          </h1>
          
          <p class="text-body-lg text-text-secondary leading-relaxed mb-8 max-w-xl mx-auto lg:mx-0 animate-fade-in-up delay-100">
            {t.home.hero.subtitle}
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start animate-fade-in-up delay-200">
            <Button href={getRoute('appointment', lang)} variant="primary" size="lg">
              {t.home.hero.cta}
            </Button>
            <Button href={getRoute('regenerative', lang)} variant="outline" size="lg">
              {t.home.hero.ctaSecondary}
            </Button>
          </div>
        </div>

        <!-- Image placeholder -->
        <div class="relative aspect-[4/3] lg:aspect-square animate-fade-in-up delay-300">
          <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-primary/5 rounded-2xl lg:rounded-3xl">
            <!-- Placeholder for hero image -->
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="text-center p-8">
                <div class="w-24 h-24 mx-auto mb-4 bg-primary/20 rounded-full flex items-center justify-center">
                  <svg class="w-12 h-12 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                  </svg>
                </div>
                <p class="text-body-sm text-text-muted">
                  [Imagen: Clínica moderna o equipo médico profesional]
                </p>
              </div>
            </div>
          </div>
          
          <!-- Floating accent -->
          <div class="absolute -bottom-4 -left-4 w-24 h-24 bg-primary rounded-2xl opacity-20 blur-sm"></div>
          <div class="absolute -top-4 -right-4 w-16 h-16 bg-primary-300 rounded-xl opacity-30"></div>
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  @keyframes fade-in-up {
    from { 
      opacity: 0;
      transform: translateY(20px);
    }
    to { 
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fade-in {
    animation: fade-in 0.6s ease-out forwards;
  }
  
  .animate-fade-in-up {
    animation: fade-in-up 0.6s ease-out forwards;
  }
  
  .delay-100 {
    animation-delay: 0.1s;
    opacity: 0;
  }
  
  .delay-200 {
    animation-delay: 0.2s;
    opacity: 0;
  }
  
  .delay-300 {
    animation-delay: 0.3s;
    opacity: 0;
  }
</style>
