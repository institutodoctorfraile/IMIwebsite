---
/**
 * Hero Section
 * Main hero banner for the homepage
 */

import { Image } from 'astro:assets';
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import { type Lang, getTranslations, getRoute } from '../../i18n';
import { SITE, SITE_LINKS } from '../../config/site';
import rafaCartelConsulta from '../../assets/rafa-cartel-consulta.jpg';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
---

<section id="hero" class="relative z-0 bg-gradient-to-br from-primary-50 via-white to-white overflow-hidden">
  <!-- Decorative elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 -left-20 w-60 h-60 bg-primary/5 rounded-full blur-3xl"></div>
  </div>

  <Container class="relative">
    <div class="py-10 md:py-20 lg:py-28">
      <div class="grid lg:grid-cols-2 gap-8 md:gap-12 lg:gap-16 items-center">
        <!-- Content -->
        <div class="text-center lg:text-left">
          <p class="text-primary font-medium text-caption sm:text-body-sm uppercase tracking-wider mb-3 sm:mb-4 animate-fade-in">
            {t.home.hero.eyebrow}
          </p>

          <h1 class="text-display-xs sm:text-display-sm md:text-display lg:text-display-lg text-text font-bold mb-4 sm:mb-6 text-balance animate-fade-in-up">
            {t.home.hero.title}
          </h1>

          <p class="text-body sm:text-body-lg text-text-secondary leading-relaxed mb-3 sm:mb-4 max-w-xl mx-auto lg:mx-0 animate-fade-in-up delay-100">
            {t.home.hero.subtitle}
          </p>

          <p class="text-body-sm sm:text-body text-primary font-medium mb-6 sm:mb-8 animate-fade-in-up delay-100">
            {t.home.hero.note}
          </p>

          <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center lg:justify-start animate-fade-in-up delay-200">
            <Button href={getRoute('patientCare', lang)} variant="primary" size="lg">
              {t.home.hero.cta}
            </Button>
            <Button href={SITE_LINKS.whatsapp} variant="outline" size="lg" external>
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              {t.home.hero.ctaWhatsapp}
            </Button>
          </div>

          <!-- Phone -->
          <p class="mt-4 text-body-sm text-text-muted animate-fade-in-up delay-300">
            {t.home.hero.callUsLabel} <a href={SITE_LINKS.tel} class="text-primary hover:text-primary-dark transition-colors font-medium">{SITE.contact.phoneDisplay}</a>
          </p>
        </div>

        <!-- Hero image -->
        <div class="relative aspect-[4/3] lg:aspect-square animate-fade-in-up delay-300">
          <Image
            src={rafaCartelConsulta}
            alt={t.home.hero.imageAlt}
            format="webp"
            quality={80}
            widths={[480, 800, 1200]}
            sizes="(min-width: 1024px) 50vw, 100vw"
            loading="eager"
            class="absolute inset-0 w-full h-full object-cover rounded-2xl lg:rounded-3xl"
          />

          <!-- Floating accent -->
          <div class="absolute -bottom-4 -left-4 w-24 h-24 bg-primary rounded-2xl opacity-20 blur-sm"></div>
          <div class="absolute -top-4 -right-4 w-16 h-16 bg-primary-300 rounded-xl opacity-30"></div>
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.6s ease-out forwards;
  }

  .animate-fade-in-up {
    animation: fade-in-up 0.6s ease-out forwards;
  }

  .delay-100 {
    animation-delay: 0.1s;
    opacity: 0;
  }

  .delay-200 {
    animation-delay: 0.2s;
    opacity: 0;
  }

  .delay-300 {
    animation-delay: 0.3s;
    opacity: 0;
  }
</style>
