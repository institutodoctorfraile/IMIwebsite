---
/**
 * What Is Regenerative Section
 * Explains regenerative gynecology
 */

import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { type Lang, getTranslations, formatTranslation } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
---

<section id="que-es" class="py-section lg:py-section-lg bg-white">
  <Container>
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Image placeholder -->
      <div class="relative order-2 lg:order-1">
        <div class="aspect-[4/3] bg-gradient-to-br from-primary-50 to-primary-100/50 rounded-2xl overflow-hidden">
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-20 h-20 mx-auto mb-4 bg-primary/20 rounded-full flex items-center justify-center">
                <svg class="w-10 h-10 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                </svg>
              </div>
              <p class="text-body-sm text-text-muted">
                {formatTranslation(t.common.imagePlaceholder, { name: t.home.whatIs.imageDescription })}
              </p>
            </div>
          </div>
        </div>
        
        <!-- Decorative elements -->
        <div class="absolute -z-10 -bottom-4 -right-4 w-full h-full bg-primary/10 rounded-2xl"></div>
      </div>

      <!-- Content -->
      <div class="order-1 lg:order-2">
        <SectionHeading
          eyebrow={t.home.whatIs.eyebrow}
          title={t.home.whatIs.title}
          description={t.home.whatIs.description}
          level={2}
          align="left"
        />
        
        <div class="mt-6 space-y-4 text-body text-text-secondary">
          <p>{t.home.whatIs.paragraph1}</p>
          <p>{t.home.whatIs.paragraph2}</p>
        </div>

        <!-- Key points -->
        <ul class="mt-8 space-y-3">
          {t.home.whatIs.keyPoints.map((point) => (
            <li class="flex items-center gap-3">
              <span class="flex-shrink-0 w-6 h-6 bg-primary/10 rounded-full flex items-center justify-center">
                <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              <span class="text-body text-text">{point}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Container>
</section>
