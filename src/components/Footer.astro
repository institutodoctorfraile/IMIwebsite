---
/**
 * Footer Component
 * Site footer with sitemap, contact info, language selector and legal
 */

import { Image } from 'astro:assets';
import logo from '../assets/logos/logo.png';
import Container from './ui/Container.astro';
import {
  type Lang,
  languages,
  getRoute,
  getEquivalentUrl,
  getTranslations,
} from '../i18n';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = getTranslations(lang);

const servicesLinks = [
  { label: t.nav.regenerativeGynecology, href: getRoute('regenerative', lang) },
  { label: t.treatments.laserCo2, href: getRoute('treatmentLaserCo2', lang) },
  { label: t.treatments.rf, href: getRoute('treatmentRf', lang) },
  { label: t.treatments.emsella, href: getRoute('treatmentEmsella', lang) },
  { label: t.treatments.prp, href: getRoute('treatmentPrp', lang) },
  { label: t.treatments.bioidenticalHt, href: getRoute('treatmentBioidenticalHt', lang) },
  { label: t.treatments.magnetotherapy, href: getRoute('treatmentMagnetotherapy', lang) },
];

const specialtiesLinks = [
  { label: t.nav.obstetrics, href: getRoute('obstetrics', lang) },
  { label: t.nav.gynecology, href: getRoute('gynecology', lang) },
  { label: t.nav.regenerativeGynecology, href: getRoute('regenerative', lang) },
];

const aboutLinks = [
  { label: t.nav.team, href: getRoute('team', lang) },
  { label: t.nav.patientCare, href: getRoute('patientCare', lang) },
];

const legalLinks = [
  { label: t.footer.privacy, href: '/privacidad' },
  { label: t.footer.terms, href: '/terminos' },
  { label: t.footer.cookies, href: '/cookies' },
];

const langOptions = Object.entries(languages).map(([code, info]) => ({
  code: code as Lang,
  name: info.nativeName,
  flag: info.flag,
  href: getEquivalentUrl(currentPath, code as Lang),
  active: code === lang,
}));
---

<footer class="bg-gray-50 border-t border-border">
  <Container>
    <!-- Main Footer Content -->
    <div class="py-12 md:py-16">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-8 lg:gap-12">
        <!-- Brand Column -->
        <div class="sm:col-span-2 lg:col-span-4">
          <a href={getRoute('home', lang)} class="inline-flex items-center gap-3 mb-4">
            <Image src={logo} alt="Instituto Ginecológico de Alicante" class="h-12 w-auto" />
            <span class="text-base font-bold text-text leading-tight">INSTITUTO DR. RAFAEL<br />FRAILE PÉREZ-CUADRADO</span>
          </a>
          <p class="text-body-sm text-text-secondary max-w-md mb-6">
            {t.footer.description}
          </p>
          <div class="flex gap-3">
            <a
              href="https://www.instagram.com/institutodrrafaelfraile/"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 flex items-center justify-center rounded-full bg-white border border-border text-text-secondary hover:text-primary hover:border-primary transition-colors"
              aria-label="Instagram"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
            <a
              href="https://www.facebook.com/institutomaternoinfantilalicante"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 flex items-center justify-center rounded-full bg-white border border-border text-text-secondary hover:text-primary hover:border-primary transition-colors"
              aria-label="Facebook"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Tratamientos -->
        <div class="lg:col-span-3">
          <h3 class="text-body font-semibold text-text mb-4">{t.nav.regenerativeGynecology}</h3>
          <ul class="space-y-2.5 list-none pl-0">
            {servicesLinks.slice(1).map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-body-sm text-text-secondary hover:text-primary transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Especialidades & Sobre nosotros -->
        <div class="lg:col-span-2">
          <h3 class="text-body font-semibold text-text mb-4">{t.footer.specialties}</h3>
          <ul class="space-y-2.5 list-none pl-0 mb-6">
            {specialtiesLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-body-sm text-text-secondary hover:text-primary transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
          <h3 class="text-body font-semibold text-text mb-4">{t.footer.about}</h3>
          <ul class="space-y-2.5 list-none pl-0">
            {aboutLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-body-sm text-text-secondary hover:text-primary transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Contact -->
        <div class="lg:col-span-3">
          <h3 class="text-body font-semibold text-text mb-4">{t.footer.contact}</h3>
          <ul class="space-y-3 text-body-sm text-text-secondary list-none pl-0">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span>{t.appointment.contact.address}</span>
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <a href={`tel:${t.appointment.contact.phone.replace(/\s/g, '')}`} class="hover:text-primary transition-colors">
                {t.appointment.contact.phone}
              </a>
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-5 h-5 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <a href={`mailto:${t.appointment.contact.email}`} class="hover:text-primary transition-colors">
                {t.appointment.contact.email}
              </a>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>{t.appointment.contact.hours}</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="py-6 border-t border-border">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <!-- Language Selector -->
        <ul class="flex items-center gap-2 list-none pl-0" aria-label={t.nav.languageSelector}>
          {langOptions.map((option, i) => (
            <>
              {i > 0 && <li class="text-text-muted" aria-hidden="true">·</li>}
              <li>
                <a
                  href={option.href}
                  class:list={[
                    'flex items-center gap-1.5 text-body-sm transition-colors',
                    option.active ? 'text-primary font-medium' : 'text-text-secondary hover:text-primary',
                  ]}
                  aria-current={option.active ? 'page' : undefined}
                >
                  <span aria-hidden="true">{option.flag}</span>
                  <span class="uppercase">{option.code}</span>
                </a>
              </li>
            </>
          ))}
        </ul>

        <ul class="flex flex-wrap justify-center gap-x-4 gap-y-2 md:gap-x-6 list-none pl-0">
          {legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-body-sm text-text-secondary hover:text-primary transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Container>
</footer>
