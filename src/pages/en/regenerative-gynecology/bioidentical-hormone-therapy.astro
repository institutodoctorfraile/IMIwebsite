---
/**
 * treatmentBioidenticalHt - Treatment Page
 * Route: /ginecologia-regenerativa/terapia-hormonal-bioidentica
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/ui/Container.astro';
import Button from '../../../components/ui/Button.astro';
import FaqAccordion from '../../../components/sections/FaqAccordion.astro';
import CtaWideCard from '../../../components/sections/CtaWideCard.astro';
import { getTranslations, getRoute, formatTranslation } from '../../../i18n';
import { SITE_LINKS } from '../../../config/site';

const lang = 'en';
const t = getTranslations(lang);
const page = t.treatmentBioidenticalHt;

const breadcrumbData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t.nav.home, item: 'https://institutoginecologicoalicante.com' },
    { '@type': 'ListItem', position: 2, name: t.regenerative.title, item: 'https://institutoginecologicoalicante.com/ginecologia-regenerativa' },
    { '@type': 'ListItem', position: 3, name: page.title },
  ],
};
---

<BaseLayout
  title={page.title}
  description={page.description}
  lang={lang}
  pageKey="treatmentBioidenticalHt"
  structuredData={breadcrumbData}
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary-50 via-white to-white py-10 md:py-20 lg:py-24">
    <Container>
      <div class="max-w-3xl">
        <p class="text-primary font-medium text-body-sm uppercase tracking-wider mb-4">
          {page.hero.eyebrow}
        </p>
        <h1 class="text-display-xs sm:text-display-sm md:text-display text-text font-bold mb-6">
          {page.hero.title}
        </h1>
        <p class="text-body-lg text-text-secondary mb-8">
          {page.hero.subtitle}
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button href={getRoute('patientCare', lang)} variant="primary" size="lg">
            {t.home.cta.button}
          </Button>
          <Button href={SITE_LINKS.whatsapp} variant="outline" size="lg" external>
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </Button>
        </div>
      </div>
    </Container>
  </section>
<!-- Cuándo puede ayudarte -->
  <section class="py-section lg:py-section-lg bg-white">
    <Container>
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-display-xs sm:text-display-sm text-text font-bold mb-6">{page.whenToConsult.title}</h2>
          <ul class="space-y-3">
            {page.whenToConsult.items.map((item: string) => (
              <li class="flex items-center gap-3">
                <span class="flex-shrink-0 w-5 h-5 text-primary">
                  <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                </span>
                <span class="text-body text-text-secondary">{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <!-- Image placeholder -->
        <div class="relative">
          <div class="aspect-[4/3] bg-gradient-to-br from-primary-50 to-primary-100/50 rounded-2xl overflow-hidden flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-16 h-16 mx-auto mb-4 bg-primary/20 rounded-full flex items-center justify-center">
                <svg class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              </div>
              <p class="text-body-sm text-text-muted">{formatTranslation(t.common.imagePlaceholder, { name: page.title })}</p>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- En qué consiste -->
  <section class="py-section lg:py-section-lg bg-gray-50">
    <Container>
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="lg:order-2">
          <h2 class="text-display-xs sm:text-display-sm text-text font-bold mb-6">{page.whatIs.title}</h2>
          {page.whatIs.content.split('\n\n').map((paragraph: string) => (
            <p class="text-body text-text-secondary mb-4 last:mb-0">{paragraph}</p>
          ))}
        </div>
        <div class="lg:order-1 relative">
          <div class="aspect-[4/3] bg-gradient-to-br from-primary-50 to-primary-100/50 rounded-2xl overflow-hidden flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-16 h-16 mx-auto mb-4 bg-primary/20 rounded-full flex items-center justify-center">
                <svg class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              </div>
              <p class="text-body-sm text-text-muted">{formatTranslation(t.common.imagePlaceholder, { name: t.common.imageProcedureLabel })}</p>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Proceso -->
  <section class="py-section lg:py-section-lg bg-white">
    <Container>
      <h2 class="text-display-xs sm:text-display-sm text-text font-bold mb-12 text-center">{page.process.title}</h2>
      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {page.process.steps.map((step: { number: string; title: string; description: string }) => (
          <div class="text-center">
            <div class="w-14 h-14 mx-auto mb-4 border-2 border-primary text-primary rounded-full flex items-center justify-center text-xl font-bold">
              {step.number}
            </div>
            <h3 class="text-subheading font-semibold text-text mb-2">{step.title}</h3>
            <p class="text-body-sm text-text-secondary">{step.description}</p>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Seguridad -->
  <section class="py-section lg:py-section-lg bg-gray-50">
    <Container>
      <div class="max-w-3xl mx-auto">
        <h2 class="text-display-xs sm:text-display-sm text-text font-bold mb-8">{page.safety.title}</h2>
        <ul class="space-y-4">
          {page.safety.items.map((item: string) => (
            <li class="flex items-start gap-4">
              <div class="flex-shrink-0 w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center mt-0.5">
                <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
              </div>
              <p class="text-body text-text-secondary pt-1">{item}</p>
            </li>
          ))}
        </ul>
      </div>
    </Container>
  </section>

  <!-- FAQs -->
  <FaqAccordion lang={lang} faqs={page.faqs.items} />

  <!-- CTA -->
  <CtaWideCard lang={lang} />
</BaseLayout>
