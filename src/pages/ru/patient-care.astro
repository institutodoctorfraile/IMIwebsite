---
/**
 * Patient Care Page - Spanish
 * Route: /ru/patient-care
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import Button from '../../components/ui/Button.astro';
import FaqAccordion from '../../components/sections/FaqAccordion.astro';
import CtaWideCard from '../../components/sections/CtaWideCard.astro';
import { getTranslations } from '../../i18n';
import { SITE, SITE_LINKS } from '../../config/site';

const lang = 'ru';
const t = getTranslations(lang);

const services = t.appointment.form.serviceOptions;
---

<BaseLayout
  title={t.patientCare.title}
  description={t.patientCare.description}
  lang={lang}
  pageKey="patientCare"
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary-50 via-white to-white py-10 md:py-20 lg:py-24">
    <Container>
      <div class="max-w-3xl">
        <p class="text-primary font-medium text-body-sm uppercase tracking-wider mb-4">
          {t.patientCare.hero.eyebrow}
        </p>
        <h1 class="text-display-xs sm:text-display-sm md:text-display text-text font-bold mb-6">
          {t.patientCare.hero.title}
        </h1>
        <p class="text-body-lg text-text-secondary">
          {t.patientCare.hero.subtitle}
        </p>
      </div>
    </Container>
  </section>
<!-- How It Works -->
  <section class="py-section lg:py-section-lg bg-gray-50">
    <Container>
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <!-- Left: heading + intro -->
        <div>
          <p class="text-primary font-medium text-body-sm uppercase tracking-wider mb-3">
            {t.patientCare.howItWorks.eyebrow}
          </p>
          <h2 class="text-heading-lg md:text-display-sm font-bold text-text mb-4">
            {t.patientCare.howItWorks.title}
          </h2>
          <p class="text-body text-text-secondary">
            {t.patientCare.howItWorks.intro}
          </p>
        </div>

        <!-- Right: numbered steps -->
        <div class="space-y-6">
          {t.patientCare.howItWorks.steps.map((step: string, index: number) => (
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-9 h-9 rounded-full bg-primary text-white flex items-center justify-center font-bold text-body-sm">
                {index + 1}
              </div>
              <p class="text-body text-text-secondary pt-1">{step}</p>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <!-- First Visit -->
  <section class="py-section lg:py-section-lg bg-white">
    <Container>
      <div class="mb-10 lg:mb-12">
        <p class="text-primary font-medium text-body-sm uppercase tracking-wider mb-3">
          {t.patientCare.firstVisit.eyebrow}
        </p>
        <h2 class="text-heading-lg md:text-display-sm font-bold text-text mb-4">
          {t.patientCare.firstVisit.title}
        </h2>
        <p class="text-body text-text-secondary max-w-2xl">
          {t.patientCare.firstVisit.intro}
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
        <!-- Card 1: Qué traer -->
        <div class="rounded-xl border border-border bg-gray-50 p-6">
          <h3 class="text-body-lg font-semibold text-text mb-4">
            {t.patientCare.firstVisit.bringTitle}
          </h3>
          <ul class="space-y-3">
            {t.patientCare.firstVisit.bringItems.map((item: string) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 flex-shrink-0 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-body-sm text-text-secondary">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Card 2: Qué esperar -->
        <div class="rounded-xl border border-border bg-gray-50 p-6">
          <h3 class="text-body-lg font-semibold text-text mb-4">
            {t.patientCare.firstVisit.expectTitle}
          </h3>
          <ul class="space-y-3">
            {t.patientCare.firstVisit.expectItems.map((item: string) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 flex-shrink-0 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-body-sm text-text-secondary">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Tip note -->
      <div class="mt-6 flex items-start gap-3 bg-primary/5 border border-primary/20 rounded-lg px-5 py-4">
        <svg class="w-5 h-5 flex-shrink-0 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-body-sm text-primary font-medium">{t.patientCare.firstVisit.tip}</p>
      </div>
    </Container>
  </section>

  <!-- Insurance -->
  <section class="py-section lg:py-section-lg bg-gray-50">
    <Container>
      <div class="max-w-3xl mx-auto">
        <p class="text-primary font-medium text-body-sm uppercase tracking-wider mb-3">
          {t.patientCare.insurance.eyebrow}
        </p>
        <h2 class="text-heading-lg md:text-display-sm font-bold text-text mb-4">
          {t.patientCare.insurance.title}
        </h2>
        <p class="text-body text-text-secondary mb-8">
          {t.patientCare.insurance.intro}
        </p>

        <ul class="space-y-4 mb-8">
          {t.patientCare.insurance.checkItems.map((item: string) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 flex-shrink-0 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-body text-text-secondary">{item}</span>
            </li>
          ))}
        </ul>

        <p class="text-body-sm text-text-muted italic">{t.patientCare.insurance.note}</p>
      </div>
    </Container>
  </section>

  <!-- Emergencies -->
  <section class="py-section lg:py-section-lg bg-white">
    <Container>
      <div class="max-w-3xl mx-auto">
        <p class="text-orange-500 font-medium text-body-sm uppercase tracking-wider mb-3">
          {t.patientCare.emergencies.eyebrow}
        </p>
        <h2 class="text-heading-lg md:text-display-sm font-bold text-text mb-4">
          {t.patientCare.emergencies.title}
        </h2>
        <p class="text-body text-text-secondary mb-8">
          {t.patientCare.emergencies.intro}
        </p>

        <ul class="space-y-4 mb-8">
          {t.patientCare.emergencies.items.map((item: string) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 flex-shrink-0 text-orange-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
              <span class="text-body text-text-secondary">{item}</span>
            </li>
          ))}
        </ul>

        <!-- 112 prominent link -->
        <div class="flex items-center gap-4 bg-orange-50 border border-orange-200 rounded-xl px-6 py-4">
          <svg class="w-8 h-8 flex-shrink-0 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <div>
            <p class="text-body-sm text-text-secondary mb-1">Emergencias</p>
            <a href="tel:112" class="text-heading font-bold text-orange-600 hover:text-orange-700 transition-colors">
              Llama al 112
            </a>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Cancellations + Location -->
  <section class="py-section lg:py-section-lg bg-gray-50">
    <Container>
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Left: Cancellations -->
        <div>
          <h2 class="text-heading-lg font-bold text-text mb-4">
            {t.patientCare.cancellations.title}
          </h2>
          <p class="text-body text-text-secondary mb-4">
            {t.patientCare.cancellations.intro}
          </p>
          <p class="text-body-sm text-text-muted italic">
            {t.patientCare.cancellations.note}
          </p>
        </div>

        <!-- Right: Location -->
        <div>
          <p class="text-primary font-medium text-body-sm uppercase tracking-wider mb-3">
            {t.patientCare.location.eyebrow}
          </p>
          <h2 class="text-heading-lg font-bold text-text mb-4">
            {t.patientCare.location.title}
          </h2>

          <!-- Address -->
          <div class="flex items-start gap-3 mb-4">
            <svg class="w-5 h-5 flex-shrink-0 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p class="text-body text-text-secondary">{t.patientCare.location.address}</p>
          </div>

          <!-- Hours note -->
          <p class="text-body-sm text-text-muted mb-6">
            {t.patientCare.location.hoursNote}
          </p>

          <!-- Contact links -->
          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href={SITE_LINKS.tel}
              class="flex items-center justify-center gap-2 px-5 py-3 rounded-lg border border-border bg-white hover:bg-gray-100 text-text font-medium text-body-sm transition-colors"
            >
              <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {SITE.contact.phoneDisplay}
            </a>
            <a
              href={SITE_LINKS.whatsapp}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 px-5 py-3 rounded-lg bg-green-500 hover:bg-green-600 text-white font-medium text-body-sm transition-colors"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp
            </a>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- FAQs -->
  <FaqAccordion lang={lang} faqs={t.patientCare.faqs.items} />

  <!-- CTA Form -->
  <section class="py-section lg:py-section-lg bg-white">
    <Container>
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Form -->
        <div>
          <h2 class="text-heading-lg font-bold text-text mb-8">
            {t.appointment.hero.title}
          </h2>
          <form class="space-y-6" action="#" method="POST">
            <!-- Name -->
            <div>
              <label for="name" class="block text-body-sm font-medium text-text mb-2">
                {t.appointment.form.name} *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder={t.appointment.form.namePlaceholder}
                class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-colors"
              />
            </div>

            <!-- Phone -->
            <div>
              <label for="phone" class="block text-body-sm font-medium text-text mb-2">
                {t.appointment.form.phone} *
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                placeholder={t.appointment.form.phonePlaceholder}
                class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-colors"
              />
            </div>

            <!-- Service / Motivo -->
            <div>
              <label for="service" class="block text-body-sm font-medium text-text mb-2">
                {t.appointment.form.service}
              </label>
              <select
                id="service"
                name="service"
                class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-colors bg-white"
              >
                <option value="">{t.appointment.form.servicePlaceholder}</option>
                {services.map((service: string) => (
                  <option value={service}>{service}</option>
                ))}
              </select>
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-body-sm font-medium text-text mb-2">
                {t.appointment.form.message}
              </label>
              <textarea
                id="message"
                name="message"
                rows="4"
                placeholder={t.appointment.form.messagePlaceholder}
                class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-colors resize-none"
              ></textarea>
            </div>

            <!-- Privacy -->
            <p class="text-body-sm text-text-secondary">
              {t.appointment.form.privacy}
            </p>

            <!-- Submit -->
            <Button type="submit" variant="primary" size="lg" fullWidth>
              {t.appointment.form.submit}
            </Button>
          </form>
        </div>

        <!-- Contact Info -->
        <div>
          <div class="bg-gray-50 rounded-2xl p-8 lg:p-10">
            <h2 class="text-heading font-semibold text-text mb-6">
              {t.appointment.contact.title}
            </h2>

            <ul class="space-y-6">
              <!-- Address -->
              <li class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-text mb-1">Dirección</p>
                  <p class="text-text-secondary">{t.appointment.contact.address}</p>
                </div>
              </li>

              <!-- Phone -->
              <li class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-text mb-1">Teléfono</p>
                  <a href={SITE_LINKS.tel} class="text-primary hover:text-primary-dark transition-colors">
                    {t.appointment.contact.phone}
                  </a>
                </div>
              </li>

              <!-- Email -->
              <li class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-text mb-1">Email</p>
                  <a href={`mailto:${t.appointment.contact.email}`} class="text-primary hover:text-primary-dark transition-colors">
                    {t.appointment.contact.email}
                  </a>
                </div>
              </li>

              <!-- Hours -->
              <li class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-text mb-1">Horario</p>
                  <p class="text-text-secondary">{t.appointment.contact.hours}</p>
                </div>
              </li>
            </ul>

            <!-- WhatsApp Button -->
            <div class="mt-8 pt-8 border-t border-border">
              <a
                href={SITE_LINKS.whatsapp}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-3 w-full py-3 px-6 bg-green-500 hover:bg-green-600 text-white font-medium rounded-lg transition-colors"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                {t.appointment.contact.whatsappCta}
              </a>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- CTA Wide Card -->
  <CtaWideCard lang={lang} />
</BaseLayout>
