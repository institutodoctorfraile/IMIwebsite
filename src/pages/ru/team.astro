---
/**
 * Team Page - Russian
 * Route: /ru/team
 */

import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
import Button from '../../components/ui/Button.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import FaqAccordion from '../../components/sections/FaqAccordion.astro';
import CtaWideCard from '../../components/sections/CtaWideCard.astro';
import { getTranslations, getRoute } from '../../i18n';
import rafaPortrait from '../../assets/rafa-portrait.jpg';
import nataliaPortrait from '../../assets/natalia-portrait.jpg';
import luciaPortrait from '../../assets/lucia-portrait.jpg';
import teamHero from '../../assets/team-hero.jpg';

const lang = 'ru';
const t = getTranslations(lang);

const memberPortraits = {
  'natalia-golubtsova': nataliaPortrait,
  'lucia-mascia': luciaPortrait,
};

const breadcrumbData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t.nav.home, item: 'https://institutoginecologicoalicante.com/ru/' },
    { '@type': 'ListItem', position: 2, name: t.team.title, item: 'https://institutoginecologicoalicante.com/ru/team' },
  ],
};
---

<BaseLayout
  title={t.team.title}
  description={t.team.description}
  lang={lang}
  pageKey="team"
  structuredData={breadcrumbData}
>
  <section class="relative overflow-hidden bg-gradient-to-br from-primary-50 via-white to-white py-10 md:py-20 lg:py-28">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-32 -right-32 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
      <div class="absolute top-1/3 -left-20 w-72 h-72 bg-primary/5 rounded-full blur-3xl"></div>
    </div>
    <Container class="relative">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-primary font-medium text-body-sm uppercase tracking-wider mb-5">
            {t.team.hero.eyebrow}
          </p>
          <h1 class="text-display-xs sm:text-display-sm md:text-display lg:text-display-lg text-text font-bold mb-6 text-balance">
            {t.team.hero.title}
          </h1>
          <p class="text-body-lg text-text-secondary leading-relaxed">
            {t.team.hero.subtitle}
          </p>
        </div>

        <div class="relative">
          <div class="absolute -inset-3 bg-primary rounded-2xl -z-10 translate-x-3 translate-y-3"></div>
          <Image
            src={teamHero}
            alt={t.team.hero.imageAlt}
            format="webp"
            quality={82}
            widths={[600, 900, 1200]}
            sizes="(min-width: 1024px) 50vw, 100vw"
            loading="eager"
            class="relative w-full h-auto rounded-2xl object-cover aspect-[4/3]"
          />
        </div>
      </div>
    </Container>
  </section>

  <section class="py-section lg:py-section-lg bg-white">
    <Container>
      <!-- Mobile title -->
      <div class="lg:hidden mb-8">
        <p class="text-primary font-medium text-body-sm uppercase tracking-wider mb-3">
          {t.team.director.eyebrow}
        </p>
        <h2 class="text-display-xs sm:text-display-sm text-text font-bold mb-2 text-balance">
          {t.team.director.name}
        </h2>
        <p class="text-body-lg text-primary font-medium">
          {t.team.director.role}
        </p>
      </div>

      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-5 lg:sticky lg:top-28">
          <div class="relative max-w-md mx-auto lg:mx-0">
            <Image
              src={rafaPortrait}
              alt={t.team.director.imageAlt}
              format="webp"
              quality={82}
              widths={[400, 600, 900]}
              sizes="(min-width: 1024px) 40vw, 100vw"
              loading="eager"
              class="relative w-full h-auto rounded-2xl object-cover aspect-[4/5]"
            />
          </div>
        </div>

        <div class="lg:col-span-7">
          <!-- Desktop title -->
          <div class="hidden lg:block mb-8">
            <p class="text-primary font-medium text-body-sm uppercase tracking-wider mb-3">
              {t.team.director.eyebrow}
            </p>
            <h2 class="text-display-xs sm:text-display-sm text-text font-bold mb-2 text-balance">
              {t.team.director.name}
            </h2>
            <p class="text-body-lg text-primary font-medium">
              {t.team.director.role}
            </p>
          </div>

          <p class="text-body text-text-secondary leading-relaxed mb-10">
            {t.team.director.bio}
          </p>

          <ul class="space-y-5 mb-10 list-none pl-0">
            {t.team.director.highlights.map((item: string) => (
              <li class="flex items-start gap-4">
                <span class="flex-shrink-0 mt-2 w-2 h-2 rounded-full bg-primary"></span>
                <span class="text-body text-text-secondary leading-relaxed [&_strong]:text-text [&_strong]:font-semibold" set:html={item} />
              </li>
            ))}
          </ul>

          <Button href={getRoute('patientCare', lang)} variant="primary" size="lg">
            {t.team.director.cta}
          </Button>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-section lg:py-section-lg bg-gray-50">
    <Container>
      <div class="text-center mb-16 lg:mb-20">
        <SectionHeading
          eyebrow={t.team.clinicalTeam.eyebrow}
          title={t.team.clinicalTeam.title}
          level={2}
          align="center"
        />
      </div>

      <div class="space-y-20 lg:space-y-32">
        {t.team.clinicalTeam.members.map((member, index: number) => {
          const portrait = memberPortraits[member.slug as keyof typeof memberPortraits];
          const reverse = index % 2 === 1;
          return (
            <div>
              <!-- Mobile title -->
              <div class="lg:hidden mb-8">
                <h3 class="text-display-xs sm:text-display-sm text-text font-bold mb-2 text-balance">
                  {member.name}
                </h3>
                <p class="text-body-lg text-primary font-medium">
                  {member.role}
                </p>
              </div>

              <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class={`lg:col-span-5 ${reverse ? 'lg:order-2' : ''}`}>
                  <div class="relative max-w-md mx-auto lg:mx-0">
                    <div class={`absolute -inset-3 bg-primary-200 rounded-2xl -z-10 ${reverse ? '-translate-x-3 translate-y-3' : 'translate-x-3 translate-y-3'}`}></div>
                    <Image
                      src={portrait}
                      alt={member.imageAlt}
                      format="webp"
                      quality={82}
                      widths={[400, 600, 900]}
                      sizes="(min-width: 1024px) 40vw, 100vw"
                      loading="lazy"
                      class="relative w-full h-auto rounded-2xl object-cover aspect-[4/5]"
                    />
                  </div>
                </div>

                <div class={`lg:col-span-7 ${reverse ? 'lg:order-1' : ''}`}>
                  <!-- Desktop title -->
                  <div class="hidden lg:block mb-8">
                    <h3 class="text-display-xs sm:text-display-sm text-text font-bold mb-2 text-balance">
                      {member.name}
                    </h3>
                    <p class="text-body-lg text-primary font-medium">
                      {member.role}
                    </p>
                  </div>

                  <p class="text-body text-text-secondary leading-relaxed mb-10">
                    {member.bio}
                  </p>

                  <ul class="space-y-5 mb-10 list-none pl-0">
                    {member.highlights.map((item: string) => (
                      <li class="flex items-start gap-4">
                        <span class="flex-shrink-0 mt-2 w-2 h-2 rounded-full bg-primary"></span>
                        <span class="text-body text-text-secondary leading-relaxed [&_strong]:text-text [&_strong]:font-semibold" set:html={item} />
                      </li>
                    ))}
                  </ul>

                  <Button href={getRoute('patientCare', lang)} variant="outline" size="lg">
                    {t.team.clinicalTeam.cta}
                  </Button>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </Container>
  </section>

  <section class="py-section lg:py-section-lg bg-white">
    <Container>
      <div class="text-center mb-12 lg:mb-16">
        <SectionHeading
          eyebrow={t.team.process.eyebrow}
          title={t.team.process.title}
          level={2}
          align="center"
        />
      </div>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-12 max-w-5xl mx-auto">
        {t.team.process.steps.map((step) => (
          <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-5 bg-primary text-white rounded-full flex items-center justify-center text-xl font-bold">
              {step.number}
            </div>
            <h3 class="text-subheading font-semibold text-text mb-3">{step.title}</h3>
            <p class="text-body-sm text-text-secondary leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>

      <p class="mt-12 text-center text-body-sm text-text-muted italic">
        {t.team.process.note}
      </p>
    </Container>
  </section>

  <FaqAccordion lang={lang} faqs={t.team.faqs.items} />

  <CtaWideCard lang={lang} />
</BaseLayout>
