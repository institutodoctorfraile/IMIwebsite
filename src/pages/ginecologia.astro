---
/**
 * Gynecology Page - Spanish
 * Route: /ginecologia
 */

import { Image } from 'astro:assets';
import gine1 from '../assets/images/gine1.jpg';
import gine2 from '../assets/images/gine2.webp';
import gine3 from '../assets/images/gine3.jpg';
import gine4 from '../assets/images/gine4.jpeg';
import gine5 from '../assets/images/gine5.jpg';
import gine6 from '../assets/images/gine6.jpg';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Button from '../components/ui/Button.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import ProcessSteps from '../components/sections/ProcessSteps.astro';
import CtaWideCard from '../components/sections/CtaWideCard.astro';
import { getTranslations, getRoute } from '../i18n';

const lang = 'es';
const t = getTranslations(lang);

// Breadcrumb structured data
const breadcrumbData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: t.nav.home,
      item: Astro.site?.toString() || 'https://institutoginecologicoalicante.com',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: t.gynecology.title,
      item: `${Astro.site?.toString() || 'https://institutoginecologicoalicante.com'}ginecologia`,
    },
  ],
};
---

<BaseLayout
  title={t.gynecology.title}
  description={t.gynecology.description}
  lang={lang}
  pageKey="gynecology"
  structuredData={breadcrumbData}
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary-50 via-white to-white py-16 md:py-24">
    <Container>
      <div class="max-w-3xl">
        <p class="text-primary font-medium text-body-sm uppercase tracking-wider mb-4">
          {t.gynecology.hero.eyebrow}
        </p>
        <h1 class="text-display-sm md:text-display text-text font-bold mb-6">
          {t.gynecology.hero.title}
        </h1>
        <p class="text-body-lg text-text-secondary">
          {t.gynecology.hero.subtitle}
        </p>
      </div>
    </Container>
  </section>
<!-- Service Sections -->
  {t.gynecology.services.map((service: { id: string; title: string; description: string; items: string[]; relatedLink?: { text: string; key: string } }, index: number) => {
    const isEven = index % 2 === 0;
    const serviceImages = [gine1, gine2, gine3, gine4, gine5, gine6];
    const serviceImage = serviceImages[index]!;

    return (
      <section id={service.id} class={`py-section lg:py-section-lg ${isEven ? 'bg-white' : 'bg-gray-50'}`}>
        <Container>
          <div class={`grid lg:grid-cols-2 gap-12 lg:gap-16 items-center ${!isEven ? 'lg:flex-row-reverse' : ''}`}>
            <!-- Content -->
            <div class={!isEven ? 'lg:order-2' : ''}>
              <SectionHeading
                title={service.title}
                description={service.description}
                level={2}
                align="left"
              />

              {service.items.length > 0 && (
                <div class="mt-8">
                  <ul class="space-y-3">
                    {service.items.map((item: string) => (
                      <li class="flex items-start gap-3">
                        <span class="flex-shrink-0 w-5 h-5 mt-0.5 text-primary">
                          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                          </svg>
                        </span>
                        <span class="text-body text-text-secondary">{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {service.relatedLink && (
                <div class="mt-6">
                  <a
                    href={getRoute(service.relatedLink.key, lang)}
                    class="inline-flex items-center gap-2 text-body-sm text-primary hover:text-primary-700 font-medium transition-colors"
                  >
                    <span>{t.common.seeMore}: {service.relatedLink.text}</span>
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </div>
              )}

              <div class="mt-8">
                <Button href={getRoute('patientCare', lang)} variant="primary">
                  {t.nav.appointment}
                </Button>
              </div>
            </div>

            <!-- Image -->
            <div class={`relative ${!isEven ? 'lg:order-1' : ''}`}>
              <div class="aspect-[4/3] rounded-2xl overflow-hidden">
                <Image src={serviceImage} alt={service.title} class={`w-full h-full object-cover ${service.id === 'menopausia' ? 'object-top' : ''}`} loading="lazy" format="webp" />
              </div>
            </div>
          </div>
        </Container>
      </section>
    );
  })}

  <!-- Process Steps -->
  <ProcessSteps lang={lang} />

  <!-- FAQs -->
  <FaqAccordion lang={lang} faqs={t.gynecology.faqs.items} />

  <!-- CTA -->
  <CtaWideCard lang={lang} />
</BaseLayout>
