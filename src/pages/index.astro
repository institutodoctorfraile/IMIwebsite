---
/**
 * Home Page - Spanish (Base Language)
 * Route: /
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import ServicesBlock from '../components/sections/ServicesBlock.astro';
import ProcessSteps from '../components/sections/ProcessSteps.astro';
import DoctorSection from '../components/sections/DoctorSection.astro';
import TrustPoints from '../components/sections/TrustPoints.astro';
import TestimonialsBlock from '../components/sections/TestimonialsBlock.astro';
import EasyProcess from '../components/sections/EasyProcess.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import CtaWideCard from '../components/sections/CtaWideCard.astro';
import { getTranslations } from '../i18n';

const lang = 'es';
const t = getTranslations(lang);

// Structured data for home page
const homeStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: t.home.title,
  description: t.home.description,
  url: Astro.site?.toString() || 'https://institutoginecologicoalicante.com',
  inLanguage: 'es-ES',
};
---

<BaseLayout
  title={t.home.title}
  description={t.home.description}
  lang={lang}
  pageKey="home"
  structuredData={homeStructuredData}
>
  <Hero lang={lang} />
  <ServicesBlock lang={lang} />
  <ProcessSteps lang={lang} />
  <DoctorSection lang={lang} />
  <TrustPoints lang={lang} />
  <TestimonialsBlock lang={lang} />
  <EasyProcess lang={lang} />
  <FaqAccordion lang={lang} />
  <CtaWideCard lang={lang} />
</BaseLayout>
