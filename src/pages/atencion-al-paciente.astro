---
/**
 * Patient Care Page - Spanish
 * Route: /atencion-al-paciente
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Button from '../components/ui/Button.astro';
import FaqAccordion from '../components/sections/FaqAccordion.astro';
import { getTranslations } from '../i18n';

const lang = 'es';
const t = getTranslations(lang);

const services = t.appointment.form.serviceOptions;
const submitted = Astro.url.searchParams.get('enviado') === '1';
---

<BaseLayout
  title={t.patientCare.title}
  description={t.patientCare.description}
  lang={lang}
  pageKey="patientCare"
>
  <!-- Solicita tu cita: text + form side by side -->
  <section class="py-section lg:py-section-lg bg-white">
    <Container>
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <!-- Left: how it works -->
        <div class="lg:sticky lg:top-28">
          <p class="text-primary font-medium text-body-sm uppercase tracking-wider mb-3">
            {t.patientCare.howItWorks.eyebrow}
          </p>
          <h1 class="text-display-sm md:text-display font-bold text-text mb-4 text-balance">
            {t.patientCare.howItWorks.title}
          </h1>
          <p class="text-body-lg text-text-secondary mb-10">
            {t.patientCare.howItWorks.intro}
          </p>

          <div class="space-y-5">
            {t.patientCare.howItWorks.steps.map((step: string, index: number) => (
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-9 h-9 rounded-full bg-primary text-white flex items-center justify-center font-bold text-body-sm">
                  {index + 1}
                </div>
                <p class="text-body text-text-secondary pt-1">{step}</p>
              </div>
            ))}
          </div>

          <!-- Aseguradoras (resumen) -->
          <div class="mt-10 p-5 rounded-xl border border-primary/20 bg-primary/5">
            <div class="flex items-center gap-2 mb-2">
              <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <h3 class="text-body font-semibold text-text">Pacientes privadas y aseguradoras</h3>
            </div>
            <p class="text-body-sm text-text-secondary">
              Atendemos pacientes privadas y trabajamos con algunas aseguradoras. Indícanos la tuya al solicitar cita y te confirmamos <strong>cobertura, autorización previa y documentación</strong> necesarias.
            </p>
          </div>

          <!-- Llámanos -->
          <a
            href="tel:+34965248558"
            class="group mt-4 flex items-center gap-4 p-5 rounded-xl border border-border bg-white hover:border-primary hover:bg-primary/5 transition-colors"
          >
            <div class="flex-shrink-0 w-11 h-11 rounded-full bg-primary/10 flex items-center justify-center group-hover:bg-primary group-hover:text-white text-primary transition-colors">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-body-sm text-text-secondary">¿Prefieres llamarnos?</p>
              <p class="text-body-lg font-semibold text-text group-hover:text-primary transition-colors">+34 965 248 558</p>
            </div>
            <svg class="w-5 h-5 text-text-muted group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <!-- Right: form -->
        <div class="bg-gray-50 rounded-2xl p-6 sm:p-8 lg:p-10 border border-border">
          <form class="space-y-5" action="?enviado=1#prepara" method="GET">
            <div>
              <label for="name" class="block text-body-sm font-medium text-text mb-2">
                {t.appointment.form.name} *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                minlength="2"
                maxlength="80"
                autocomplete="name"
                placeholder={t.appointment.form.namePlaceholder}
                class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-colors bg-white"
              />
            </div>

            <div>
              <label for="phone" class="block text-body-sm font-medium text-text mb-2">
                {t.appointment.form.phone} *
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                inputmode="tel"
                pattern="[+0-9\s().-]{9,20}"
                minlength="9"
                maxlength="20"
                autocomplete="tel"
                placeholder={t.appointment.form.phonePlaceholder}
                class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-colors bg-white"
              />
            </div>

            <div>
              <label for="service" class="block text-body-sm font-medium text-text mb-2">
                {t.appointment.form.service}
              </label>
              <select
                id="service"
                name="service"
                class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-colors bg-white"
              >
                <option value="">{t.appointment.form.servicePlaceholder}</option>
                {services.map((service: string) => (
                  <option value={service}>{service}</option>
                ))}
              </select>
            </div>

            <div>
              <label for="message" class="block text-body-sm font-medium text-text mb-2">
                {t.appointment.form.message}
              </label>
              <textarea
                id="message"
                name="message"
                rows="4"
                maxlength="300"
                placeholder={t.appointment.form.messagePlaceholder}
                class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-colors resize-none bg-white"
                data-message-input
              ></textarea>
              <p class="mt-1.5 text-right text-[12px] text-text-muted">
                <span data-message-count>0</span>/300
              </p>
            </div>

            <p class="text-body-sm text-text-secondary">
              {t.appointment.form.privacy}
            </p>

            <Button type="submit" variant="primary" size="lg" fullWidth>
              {t.appointment.form.submit}
            </Button>

            <a
              href="https://wa.me/34652582768"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full py-3 px-6 bg-green-500 hover:bg-green-600 text-white font-medium rounded-lg transition-colors"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              {t.appointment.contact.whatsappCta}
            </a>
          </form>
        </div>
      </div>
    </Container>
  </section>

  {submitted && (
    <!-- First Visit (shown after form submit) -->
    <section id="prepara" class="py-section lg:py-section-lg bg-white border-t border-border">
      <Container>
        <div class="mb-10 lg:mb-12 max-w-3xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-6 rounded-full bg-primary/10 text-primary text-body-sm font-medium">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            Solicitud recibida
          </div>
          <p class="text-primary font-medium text-body-sm uppercase tracking-wider mb-3">
            {t.patientCare.firstVisit.eyebrow}
          </p>
          <h2 class="text-heading-lg md:text-display-sm font-bold text-text mb-4">
            {t.patientCare.firstVisit.title}
          </h2>
          <p class="text-body text-text-secondary">
            {t.patientCare.firstVisit.intro}
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 lg:gap-8 max-w-5xl mx-auto">
          <div class="rounded-xl border border-border bg-gray-50 p-6">
            <h3 class="text-body-lg font-semibold text-text mb-4">
              {t.patientCare.firstVisit.bringTitle}
            </h3>
            <ul class="space-y-3">
              {t.patientCare.firstVisit.bringItems.map((item: string) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 flex-shrink-0 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-body-sm text-text-secondary">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="rounded-xl border border-border bg-gray-50 p-6">
            <h3 class="text-body-lg font-semibold text-text mb-4">
              {t.patientCare.firstVisit.expectTitle}
            </h3>
            <ul class="space-y-3">
              {t.patientCare.firstVisit.expectItems.map((item: string) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 flex-shrink-0 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-body-sm text-text-secondary">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="max-w-5xl mx-auto mt-6 flex items-start gap-3 bg-primary/5 border border-primary/20 rounded-lg px-5 py-4">
          <svg class="w-5 h-5 flex-shrink-0 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-body-sm text-primary font-medium">{t.patientCare.firstVisit.tip}</p>
        </div>
      </Container>
    </section>
  )}

  <!-- Emergencies -->
  <section class="py-section lg:py-section-lg bg-white">
    <Container>
      <div class="max-w-3xl mx-auto">
        <p class="text-orange-500 font-medium text-body-sm uppercase tracking-wider mb-3">
          {t.patientCare.emergencies.eyebrow}
        </p>
        <h2 class="text-heading-lg md:text-display-sm font-bold text-text mb-4">
          {t.patientCare.emergencies.title}
        </h2>
        <p class="text-body text-text-secondary mb-8">
          {t.patientCare.emergencies.intro}
        </p>

        <ul class="space-y-4 mb-8">
          {t.patientCare.emergencies.items.map((item: string) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 flex-shrink-0 text-orange-500 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
              <span class="text-body text-text-secondary">{item}</span>
            </li>
          ))}
        </ul>

        <div class="flex items-center gap-4 bg-orange-50 border border-orange-200 rounded-xl px-6 py-4">
          <svg class="w-8 h-8 flex-shrink-0 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <div>
            <p class="text-body-sm text-text-secondary mb-1">Emergencias</p>
            <a href="tel:112" class="text-heading font-bold text-orange-600 hover:text-orange-700 transition-colors">
              Llama al 112
            </a>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- FAQs -->
  <FaqAccordion lang={lang} faqs={t.patientCare.faqs.items} />

  <script>
    const input = document.querySelector<HTMLTextAreaElement>('[data-message-input]');
    const counter = document.querySelector<HTMLSpanElement>('[data-message-count]');
    if (input && counter) {
      const update = () => { counter.textContent = String(input.value.length); };
      input.addEventListener('input', update);
      update();
    }
  </script>
</BaseLayout>
